# =============================================================================
# .gitignore - Kbine MCP Server
# =============================================================================

# -----------------------------------------------------------------------------
# Dependances
# -----------------------------------------------------------------------------
node_modules/
package-lock.json

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------
dist/
*.js.map

# -----------------------------------------------------------------------------
# Environnement
# -----------------------------------------------------------------------------
# IMPORTANT: Ne jamais commiter le fichier .env avec les credentials
.env
.env.local
.env.*.local
.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*

# -----------------------------------------------------------------------------
# IDE et editeurs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Ne pas ignorer les Dockerfiles et docker-compose
# Mais ignorer les volumes locaux
docker-data/

# -----------------------------------------------------------------------------
# Tests
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Divers
# -----------------------------------------------------------------------------
.cache/
tmp/
temp/
*.tmp


scripts/*
