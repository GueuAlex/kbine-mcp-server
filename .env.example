# =============================================================================
# Configuration du serveur MCP Kbine Reports
# =============================================================================
#
# Copier ce fichier vers .env et remplir les valeurs.
# Ne JAMAIS commiter le fichier .env avec les vrais credentials.
#
# DEVELOPPEMENT LOCAL:
#   Les valeurs par defaut fonctionnent avec docker-compose.yml
#
# PRODUCTION:
#   Modifier les valeurs pour pointer vers la vraie base de donnees
# =============================================================================

# -----------------------------------------------------------------------------
# Base de donnees MySQL
# -----------------------------------------------------------------------------

# Adresse du serveur MySQL
# - Developpement: kbine-mcp-mysql (nom du container Docker)
# - Production: kbine-mysql (container existant du backend)
DB_HOST=kbine-mysql

# Port MySQL (3306 par defaut)
DB_PORT=3306

# Utilisateur MySQL avec droits SELECT uniquement
# Cet utilisateur a ete cree specifiquement pour le MCP
DB_USER=kbine_readonly

# Mot de passe de l'utilisateur read-only
# IMPORTANT: Utiliser un mot de passe fort en production
DB_PASSWORD=

# Nom de la base de donnees
DB_NAME=kbine_db

# -----------------------------------------------------------------------------
# Serveur HTTP
# -----------------------------------------------------------------------------

# Port d'ecoute du serveur
# Le serveur MCP ecoute sur ce port
PORT=3001

# Environnement (development ou production)
# En production, les messages d'erreur sont moins detailles
NODE_ENV=production
